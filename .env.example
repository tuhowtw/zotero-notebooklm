# Zotero credentials
# Get these from https://www.zotero.org/settings/keys
#
# Your numeric userID shown at the top of the keys page
ZOTERO_LIBRARY_ID=

# API key with Read Only access (create a new key on the same page)
ZOTERO_API_KEY=

# "user" for personal library, "group" for a group library
ZOTERO_LIBRARY_TYPE=user

# (Optional) Path to your local Zotero storage folder.
# Only needed if your PDFs are NOT synced to Zotero cloud.
# Default locations (auto-detected):
#   Windows : %APPDATA%\Zotero\Zotero\storage
#   Mac/Linux: ~/Zotero/storage
# ZOTERO_DATA_DIR=
